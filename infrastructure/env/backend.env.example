APP_NAME=EinsatzWerk
APP_ENV=production
APP_KEY=GENERATE_WITH_PHP_ARTISAN_KEY_GENERATE_SHOW
APP_DEBUG=false
APP_URL=https://api.einsatz-werk.de
FRONTEND_URL=https://app.einsatz-werk.de
LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=einsatzwerk
DB_USERNAME=einsatzwerk
DB_PASSWORD=CHANGE_ME

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

FILESYSTEM_DISK=local
MAP_GEOCODING_PROVIDER=nominatim
MAP_GEOCODING_URL=https://nominatim.openstreetmap.org
MAP_ROUTING_PROVIDER=osrm
MAP_ROUTING_URL=https://router.project-osrm.org
MAP_USER_AGENT="EinsatzWerk/1.0 kontakt@einsatz-werk.de"
