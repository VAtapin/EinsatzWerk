upstream einsatzwerk_web {
    server 127.0.0.1:3000;
    keepalive 32;
}

server {
    listen 80;
    listen [::]:80;
    server_name einsatz-werk.de;
    return 302 http://app.einsatz-werk.de$request_uri;
}

server {
    listen 80;
    listen [::]:80;
    server_name app.einsatz-werk.de;

    location / {
        proxy_pass http://einsatzwerk_web;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}

server {
    listen 80;
    listen [::]:80;
    server_name api.einsatz-werk.de;
    root /var/www/einsatzwerk/current/apps/backend/public;
    index index.php;
    client_max_body_size 30m;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include snippets/fastcgi-php.conf;
        fastcgi_pass unix:/run/php/php-fpm.sock;
    }

    location ~ /\.(?!well-known).* {
        deny all;
    }
}
