[Unit]
Description=EinsatzWerk Laravel queue worker
After=network.target redis.service postgresql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/einsatzwerk/current/apps/backend
EnvironmentFile=/var/www/einsatzwerk/shared/backend.env
ExecStart=/usr/bin/php artisan queue:work redis --sleep=1 --tries=3 --timeout=120
Restart=always
RestartSec=5
TimeoutStopSec=3600

[Install]
WantedBy=multi-user.target
