[Unit]
Description=EinsatzWerk Laravel scheduler
After=network.target redis.service postgresql.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/var/www/einsatzwerk/current/apps/backend
EnvironmentFile=/var/www/einsatzwerk/shared/backend.env
ExecStart=/usr/bin/php artisan schedule:work
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
